# --- Database ---
POSTGRES_USER=overhearr
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=overhearr_db
POSTGRES_PORT=5432
POSTGRES_DATA=postgres_data:/var/lib/postgresql/data

# --- Backend ---
BACKEND_PORT=8080
# Generate a secure random string for JWT or Session signing
APP_SECRET=replace_this_with_long_random_string_base64_encoded
TOKEN_EXPIRATION=730d
DEFAULT_ADMIN_USERNAME=admin
# Use a secure password instead
DEFAULT_ADMIN_PASSWORD=admin
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2

# --- Frontend ---
FRONTEND_PORT=80

# --- APIs ---
DEEZER_BASE_URL=https://api.deezer.com